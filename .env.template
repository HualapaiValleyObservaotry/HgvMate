# ─────────────────────────────────────────────────────────────────────
# HgvMate — Environment Variable Template
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.
#
# For dev containers, these are forwarded via remoteEnv in devcontainer.json.
# For Docker/Azure Container Apps, pass via -e flags or Azure configuration.
# ─────────────────────────────────────────────────────────────────────

# Azure DevOps PAT — used for cloning repos and accessing work items
# Scopes: Code (Read), Work Items (Read)
AZURE_DEVOPS_PAT=

# GitHub PAT — used for cloning GitHub repos (optional, for public repos)
GITHUB_TOKEN=

# Data directory — where SQLite DBs, cloned repos, and ONNX model are stored
# Default: /data (Docker) or .data (local dev)
HGVMATE_DATA_PATH=

# Proxmox API — used for deployment to local Proxmox host
PVE_HOST=
PVE_USER=
PVE_TOKEN=

# Remote Docker hosts — used to create Docker contexts on dev container startup
# Mac Mini running HgvMate (Docker context: mac)
MAC_HOST=
MAC_USER=

# Proxmox LXC container running HgvMate (Docker context: lxc)
LXC_HOST=
LXC_USER=
