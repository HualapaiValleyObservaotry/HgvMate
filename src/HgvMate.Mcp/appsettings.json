{
  "HgvMate": {
    "DataPath": "./data",
    "Transport": "stdio"
  },
  "RepoSync": {
    "PollIntervalMinutes": 15,
    "ClonePath": "repos"
  },
  "Search": {
    "MaxResults": 20,
    "ChunkSize": 800,
    "ChunkOverlap": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
